[0].Seed                                          language CppStmts ...  
  [0].Seed.Language                               language CppStmts ...  
    [0].Seed.Rule                                 skip = ... free_form \n
      [0].Seed.Nonterminal                        skip
      [1].Seed.Nonterminal                        skip . free_form
    [1].Seed.Rule                                 ⊙ = ... * \n  
      [0].Seed.Expr.Postfix.*                     ( Expr ';' ) *
        [0].Seed.Expr.Concat.concat               Expr ';'
          [0].Seed.Nonterminal                    Expr
          [1].Seed.Terminal                       ';'
    [2].Seed.Scope                                Expr : ... \n 
      [0].Seed.Nonterminal                        Expr
      [1].Seed.Rule                               ⊙ = ... \n     
        [0].Seed.Axe                              Atom oper ... \n     
          [0].Seed.Nonterminal                    Atom
          [1].Seed.Nonterminal                    oper
          [2].Seed.Axe.Level                      Namespace = ... prefix '::'
            [0].Seed.Axe.Assoc                    rtl
            [1].Seed.Axe.Ops                      infix '::'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '::'
            [2].Seed.Axe.Ops                      prefix '::'
              [0].Seed.Axe.OpType                 prefix
              [1].Seed.Axe.Op                     '::'
          [3].Seed.Axe.Level                      Postfix = ... '.' '->'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      postfix '++' '--'
              [0].Seed.Axe.OpType                 postfix
              [1].Seed.Axe.Op                     '++'
              [2].Seed.Axe.Op                     '--'
            [2].Seed.Axe.Ops                      postfix_nest '(' ')' '[' ']'
              [0].Seed.Axe.OpType                 postfix_nest
              [1].Seed.Axe.Op                     '('
              [2].Seed.Axe.Op                     ')'
              [3].Seed.Axe.Op                     '['
              [4].Seed.Axe.Op                     ']'
            [3].Seed.Axe.Ops                      infix '.' '->'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '.'
              [2].Seed.Axe.Op                     '->'
          [4].Seed.Axe.Level                      Prefix = ... '(' ')'
            [0].Seed.Axe.Assoc                    rtl
            [1].Seed.Axe.Ops                      prefix '++' ... "sizeof" "new"
              [0].Seed.Axe.OpType                 prefix
              [1].Seed.Axe.Op                     '++'
              [2].Seed.Axe.Op                     '--'
              [3].Seed.Axe.Op                     '+'
              [4].Seed.Axe.Op                     '-'
              [5].Seed.Axe.Op                     '!'
              [6].Seed.Axe.Op                     '~'
              [7].Seed.Axe.Op                     '*'
              [8].Seed.Axe.Op                     '&'
              [9].Seed.Axe.Op                     "sizeof"
              [10].Seed.Axe.Op                    "new"
            [2].Seed.Axe.Ops                      prefix_nest -> Type '(' ')'
              [0].Seed.Axe.OpType                 prefix_nest
              [1].Seed.Nonterminal                Type
              [2].Seed.Axe.Op                     '('
              [3].Seed.Axe.Op                     ')'
          [5].Seed.Axe.Level                      Member = ... '.*' '->*'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '.*' '->*'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '.*'
              [2].Seed.Axe.Op                     '->*'
          [6].Seed.Axe.Level                      Multiply = ... '/' '%'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '*' '/' '%'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '*'
              [2].Seed.Axe.Op                     '/'
              [3].Seed.Axe.Op                     '%'
          [7].Seed.Axe.Level                      Addition = ... '+' '-'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '+' '-'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '+'
              [2].Seed.Axe.Op                     '-'
          [8].Seed.Axe.Level                      Bitshift = ... '<<' '>>'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '<<' '>>'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '<<'
              [2].Seed.Axe.Op                     '>>'
          [9].Seed.Axe.Level                      Spaceship = ltr infix '<=>'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '<=>'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '<=>'
          [10].Seed.Axe.Level                     Comparison = ... '>' '>='
