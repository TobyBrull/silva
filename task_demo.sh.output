[0].Seed                                          language Soil ...  
  [0].Seed.Language                               language Soil ...  
    [0].Seed.Rule                                 skip = ... free_form \n
      [0].Seed.Nonterminal                        skip
      [1].Seed.Nonterminal                        skip . free_form
    [1].Seed.Rule                                 type_name = 't_' identifier \n  
      [0].Seed.Nonterminal                        type_name
      [1].Seed.Expr.Concat.concat                 't_' identifier
        [0].Seed.Terminal                         't_'
        [1].Seed.Nonterminal                      identifier
    [2].Seed.Rule                                 func_name = 'f_' identifier \n
      [0].Seed.Nonterminal                        func_name
      [1].Seed.Expr.Concat.concat                 'f_' identifier
        [0].Seed.Terminal                         'f_'
        [1].Seed.Nonterminal                      identifier
    [3].Seed.Rule                                 ⊙ = ... * \n  
      [0].Seed.Expr.Postfix.*                     ( Type ... ) *
        [0].Seed.Expr.Or.|                        Type . ... . Defn
          [0].Seed.Nonterminal                    Type . Defn
          [1].Seed.Nonterminal                    Func . Defn
          [2].Seed.Nonterminal                    Variable . Defn
    [4].Seed.Scope                                Type : ...    
      [0].Seed.Nonterminal                        Type
      [1].Seed.Rule                               ⊙ = ... Struct \n    
        [0].Seed.Expr.Or.|                        Name | Struct
          [0].Seed.Nonterminal                    Name
          [1].Seed.Nonterminal                    Struct
      [2].Seed.Rule                               Name = type_name \n    
        [0].Seed.Nonterminal                      Name
        [1].Seed.Nonterminal                      type_name
      [3].Seed.Rule                               Defn = ... Type \n    
        [0].Seed.Nonterminal                      Defn
        [1].Seed.Expr.Concat.concat               Name '=' Type
          [0].Seed.Nonterminal                    Name
          [1].Seed.Terminal                       '='
          [2].Seed.Nonterminal                    Type
      [4].Seed.Scope                              Struct : ...  
        [0].Seed.Nonterminal                      Struct
        [1].Seed.Rule                             ⊙ = ... ']' \n      
          [0].Seed.Expr.Concat.concat             '[' Member * ']'
            [0].Seed.Terminal                     '['
            [1].Seed.Expr.Postfix.*               Member *
              [0].Seed.Nonterminal                Member
            [2].Seed.Terminal                     ']'
        [2].Seed.Scope                            Member : ... \n 
          [0].Seed.Nonterminal                    Member
          [1].Seed.Rule                           ⊙ = ... ';' \n        
            [0].Seed.Expr.Concat.concat           Type Label ... ? ';'
              [0].Seed.Nonterminal                Type
              [1].Seed.Expr.Postfix.?             Label ?
                [0].Seed.Nonterminal              Label
              [2].Seed.Expr.Postfix.?             Init ?
                [0].Seed.Nonterminal              Init
              [3].Seed.Terminal                   ';'
          [2].Seed.Rule                           Label = ':' Name \n        
            [0].Seed.Nonterminal                  Label
            [1].Seed.Expr.Concat.concat           ':' Name
              [0].Seed.Terminal                   ':'
              [1].Seed.Nonterminal                Name
          [3].Seed.Rule                           Init = '=' Expr \n        
            [0].Seed.Nonterminal                  Init
            [1].Seed.Expr.Concat.concat           '=' Expr
              [0].Seed.Terminal                   '='
              [1].Seed.Nonterminal                Expr
          [4].Seed.Rule                           Name = identifier \n
            [0].Seed.Nonterminal                  Name
            [1].Seed.Nonterminal                  identifier
    [5].Seed.Scope                                Expr : ...    
      [0].Seed.Nonterminal                        Expr
      [1].Seed.Rule                               ⊙ = Axe \n    
        [0].Seed.Nonterminal                      Axe
      [2].Seed.Rule                               Maybe = ... ε \n    
        [0].Seed.Nonterminal                      Maybe
        [1].Seed.Expr.Or.|                        Expr | ε
          [0].Seed.Nonterminal                    Expr
          [1].Seed.Terminal                       ε
      [3].Seed.Rule                               Axe = ... \n     
        [0].Seed.Nonterminal                      Axe
        [1].Seed.Axe                              Atom oper ... \n     
          [0].Seed.Nonterminal                    Atom
          [1].Seed.Nonterminal                    oper
          [2].Seed.Axe.Level                      Member = ltr infix '.'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '.'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '.'
          [3].Seed.Axe.Level                      CallPost = ... '(' ')'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      postfix_nest '(' ')'
              [0].Seed.Axe.OpType                 postfix_nest
              [1].Seed.Axe.Op                     '('
              [2].Seed.Axe.Op                     ')'
          [4].Seed.Axe.Level                      Typing = ltr infix '::'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '::'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '::'
          [5].Seed.Axe.Level                      CallPipe = ltr infix '|'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '|'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '|'
          [6].Seed.Axe.Level                      Mul = ... '*' '//'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '*' '//'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '*'
              [2].Seed.Axe.Op                     '//'
          [7].Seed.Axe.Level                      Add = ... '+' '-'
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '+' '-'
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '+'
              [2].Seed.Axe.Op                     '-'
          [8].Seed.Axe.Level                      Comp = ... '>' '>='
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '==' ... '>' '>='
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '=='
              [2].Seed.Axe.Op                     '<='
              [3].Seed.Axe.Op                     '<'
              [4].Seed.Axe.Op                     '>'
              [5].Seed.Axe.Op                     '>='
          [9].Seed.Axe.Level                      Logic = ... "and" "or"
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix "and" "or"
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     "and"
              [2].Seed.Axe.Op                     "or"
          [10].Seed.Axe.Level                     Assign = ... '+=' '*='
            [0].Seed.Axe.Assoc                    ltr
            [1].Seed.Axe.Ops                      infix '=' '+=' '*='
              [0].Seed.Axe.OpType                 infix
              [1].Seed.Axe.Op                     '='
              [2].Seed.Axe.Op                     '+='
              [3].Seed.Axe.Op                     '*='
      [4].Seed.Rule                               Atom = ... ) \n    
        [0].Seed.Nonterminal                      Atom
        [1].Seed.Expr.Or.|                        Struct | ... Expr ')'
          [0].Seed.Nonterminal                    Struct
          [1].Seed.Terminal                       language
          [2].Seed.Nonterminal                    type_name
          [3].Seed.Nonterminal                    func_name
          [4].Seed.Nonterminal                    identifier
          [5].Seed.Nonterminal                    string
          [6].Seed.Nonterminal                    number
          [7].Seed.Terminal                       "true"
          [8].Seed.Terminal                       "false"
          [9].Seed.Terminal                       "none"
          [10].Seed.Expr.Concat.concat            '(' Expr ')'
            [0].Seed.Terminal                     '('
            [1].Seed.Nonterminal                  Expr
            [2].Seed.Terminal                     ')'
      [5].Seed.Rule                               oper = ... parenthesis \n    
        [0].Seed.Nonterminal                      oper
        [1].Seed.Expr.Or.|                        operator . greedy | parenthesis
          [0].Seed.Nonterminal                    operator . greedy
          [1].Seed.Nonterminal                    parenthesis
      [6].Seed.Scope                              Struct : ... \n 
        [0].Seed.Nonterminal                      Struct
        [1].Seed.Rule                             ⊙ = ... ']' \n      
          [0].Seed.Expr.Concat.concat             '[' LabeledItem * ']'
            [0].Seed.Terminal                     '['
            [1].Seed.Expr.Postfix.*               LabeledItem *
              [0].Seed.Nonterminal                LabeledItem
            [2].Seed.Terminal                     ']'
        [2].Seed.Rule                             LabeledItem = ... ) \n
          [0].Seed.Nonterminal                    LabeledItem
          [1].Seed.Expr.Concat.concat             ( Variable ... Expr )
            [0].Seed.Expr.Postfix.?               ( Variable ... ) ?
              [0].Seed.Expr.Concat.concat         Variable . Name ':'
                [0].Seed.Nonterminal              Variable . Name
                [1].Seed.Terminal                 ':'
            [1].Seed.Expr.Or.|                    Struct | Expr
              [0].Seed.Nonterminal                Struct
              [1].Seed.Nonterminal                Expr
    [6].Seed.Scope                                Func : ...    
      [0].Seed.Nonterminal                        Func
      [1].Seed.Rule                               ⊙ = Name \n    
        [0].Seed.Nonterminal                      Name
      [2].Seed.Rule                               Name = func_name \n    
        [0].Seed.Nonterminal                      Name
        [1].Seed.Nonterminal                      func_name
      [3].Seed.Rule                               Defn = ... Body \n    
        [0].Seed.Nonterminal                      Defn
        [1].Seed.Expr.Concat.concat               Name '=' Signature Body
          [0].Seed.Nonterminal                    Name
          [1].Seed.Terminal                       '='
          [2].Seed.Nonterminal                    Signature
          [3].Seed.Nonterminal                    Body
      [4].Seed.Rule                               Signature = ... ? \n    
        [0].Seed.Nonterminal                      Signature
        [1].Seed.Expr.Concat.concat               Type ( ... ) ?
          [0].Seed.Nonterminal                    Type
          [1].Seed.Expr.Postfix.?                 ( '->' Type ) ?
            [0].Seed.Expr.Concat.concat           '->' Type
              [0].Seed.Terminal                   '->'
              [1].Seed.Nonterminal                Type
      [5].Seed.Rule                               Body = ... '}' \n    
        [0].Seed.Nonterminal                      Body
        [1].Seed.Expr.Concat.concat               '{' Stmt * '}'
          [0].Seed.Terminal                       '{'
          [1].Seed.Expr.Postfix.*                 Stmt *
            [0].Seed.Nonterminal                  Stmt
          [2].Seed.Terminal                       '}'
      [6].Seed.Scope                              Stmt : ... \n 
        [0].Seed.Nonterminal                      Stmt
        [1].Seed.Rule                             ⊙ = ... ';' \n      
          [0].Seed.Expr.Or.|                      If | ... Expr ';'
            [0].Seed.Nonterminal                  If
            [1].Seed.Nonterminal                  For
            [2].Seed.Expr.Concat.concat           Expr ';'
              [0].Seed.Nonterminal                Expr
              [1].Seed.Terminal                   ';'
        [2].Seed.Scope                            If : ... \n       
          [0].Seed.Nonterminal                    If
          [1].Seed.Rule                           ⊙ = ... ? \n        
            [0].Seed.Expr.Concat.concat           "if" Branch ... ) ?
              [0].Seed.Terminal                   "if"
              [1].Seed.Nonterminal                Branch
              [2].Seed.Expr.Postfix.*             ( "elif" Branch ) *
                [0].Seed.Expr.Concat.concat       "elif" Branch
                  [0].Seed.Terminal               "elif"
                  [1].Seed.Nonterminal            Branch
              [3].Seed.Expr.Postfix.?             ( "else" Body ) ?
                [0].Seed.Expr.Concat.concat       "else" Body
                  [0].Seed.Terminal               "else"
                  [1].Seed.Nonterminal            Body
          [2].Seed.Rule                           Branch = Expr Body \n
            [0].Seed.Nonterminal                  Branch
            [1].Seed.Expr.Concat.concat           Expr Body
              [0].Seed.Nonterminal                Expr
              [1].Seed.Nonterminal                Body
        [3].Seed.Rule                             For = ... Body \n
          [0].Seed.Nonterminal                    For
          [1].Seed.Expr.Concat.concat             "for" Expr ... Maybe Body
            [0].Seed.Terminal                     "for"
            [1].Seed.Nonterminal                  Expr . Maybe
            [2].Seed.Terminal                     ';'
            [3].Seed.Nonterminal                  Expr . Maybe
            [4].Seed.Terminal                     ';'
            [5].Seed.Nonterminal                  Expr . Maybe
            [6].Seed.Nonterminal                  Body
    [7].Seed.Scope                                Variable : ... \n 
      [0].Seed.Nonterminal                        Variable
      [1].Seed.Rule                               Name = ... identifier \n    
        [0].Seed.Nonterminal                      Name
        [1].Seed.Expr.And.but_then                not Type ... but_then identifier
          [0].Seed.Expr.Prefix.not                not Type . Name
            [0].Seed.Nonterminal                  Type . Name
          [1].Seed.Expr.Prefix.not                not Func . Name
            [0].Seed.Nonterminal                  Func . Name
          [2].Seed.Nonterminal                    identifier
      [2].Seed.Rule                               Defn = ... Expr \n
        [0].Seed.Nonterminal                      Defn
        [1].Seed.Expr.Concat.concat               Name '=' Expr
          [0].Seed.Nonterminal                    Name
